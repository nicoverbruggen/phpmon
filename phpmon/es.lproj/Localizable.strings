"onboarding_wizard.detail.homebrew.title" = "Paso 2: Instalar Homebrew";
"onboarding_wizard.detail.homebrew.description" = "Homebrew es necesario para instalar PHP, Composer y otros requisitos previos (como los que necesita Valet).\n\nCopia el siguiente comando, ejecútalo en Terminal, completa allí la instalación y luego vuelve aquí.";
"onboarding_wizard.detail.homebrew.waiting" = "Ejecuta el comando de instalación de Homebrew en Terminal, completa allí la instalación, luego vuelve aquí y haz clic en Comprobar de nuevo.";
"onboarding_wizard.detail.path.title" = "Paso 2: Configurar tu PATH";
"onboarding_wizard.detail.path.description.zsh" = "Homebrew está instalado, pero tu PATH todavía debe incluir el directorio bin global de Composer y el directorio bin de Homebrew para darte acceso a estas herramientas desde la línea de comandos.\n\nPHP Monitor puede actualizar tu `~/.zshrc` automáticamente y añadirlos a tu PATH. (También se añadirán algunas utilidades útiles proporcionadas por PHP Monitor para cambiar fácilmente de versión de PHP.)";
"onboarding_wizard.detail.path.description.manual" = "Homebrew está instalado, pero tu shell configurado (%@) no es zsh. Añade las líneas siguientes al perfil de tu shell, abre una nueva sesión de Terminal y luego haz clic en Comprobar de nuevo.";
"onboarding_wizard.detail.php_composer.title" = "Paso 3: Instalar PHP y Composer";
"onboarding_wizard.detail.php_composer.description" = "Tanto PHP como Composer deben estar instalados antes de que PHP Monitor pueda funcionar correctamente. Para ponértelo fácil, PHP Monitor instalará ambos automáticamente.";
"onboarding_wizard.detail.valet.title" = "Paso 4: Instalar Valet";
"onboarding_wizard.detail.valet.description" = "PHP Monitor puede instalar Laravel Valet y configurarlo automáticamente por ti. Durante este proceso se te pedirá tu contraseña de administrador dos veces.\n\n(Si lo prefieres, también puedes omitir este paso y usar el modo independiente por ahora. Siempre puedes instalar Valet más tarde.)";
"onboarding_wizard.detail.ready.title" = "Paso 5: Finalizar configuración";
"onboarding_wizard.detail.ready.description" = "¡Buenas noticias! Tu sistema ya está configurado correctamente. Haz clic en Continuar y PHP Monitor volverá a ejecutar sus comprobaciones de inicio. Si todo va bien, el icono aparecerá en la barra de menús.";
