"onboarding_wizard.alert.developer_tools_incomplete.description" = "Termina el instalador que abrió macOS y luego haz clic en Continuar de nuevo. Si el instalador no apareció, puedes ejecutar este comando en Terminal:\n\n/usr/bin/xcode-select --install";
